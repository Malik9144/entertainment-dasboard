{
  "name": "entertainment-dashboard-backend",
  "version": "1.0.0",
  "description": "Entertainment & Event Dashboard API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "migrate": "node --loader ts-node/esm src/migrations/run.ts",
    "seed": "node --loader ts-node/esm src/migrations/seed.ts",
    "test": "jest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src"
  },
  "keywords": ["entertainment", "dashboard", "api", "express"],
  "author": "Malik9144",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "postgres": "^14.9.0",
    "jsonwebtoken": "^9.0.2",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "helmet": "^7.1.0",
    "uuid": "^9.0.1",
    "redis": "^4.6.11",
    "ws": "^8.14.2",
    "pino": "^8.16.2",
    "pino-pretty": "^10.2.3",
    "express-rate-limit": "^7.0.0",
    "class-validator": "^0.14.0",
    "class-transformer": "^0.5.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.9.0",
    "@types/jsonwebtoken": "^9.0.6",
    "typescript": "^5.2.2",
    "ts-node-dev": "^2.0.0",
    "ts-node": "^10.9.1",
    "prettier": "^3.1.0",
    "eslint": "^8.52.0",
    "@typescript-eslint/eslint-plugin": "^6.11.0",
    "@typescript-eslint/parser": "^6.11.0"
  }
}
